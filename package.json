{
  "name": "algo-notes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "gen:content": "node scripts/gen-content.mjs",
    "predev": "npm run gen:content",
    "dev": "next dev",
    "prebuild": "npm run gen:content",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pretest": "npm run gen:content",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "npm run gen:content && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run gen:content && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.86",
    "@ai-sdk/groq": "^3.0.45",
    "@ai-sdk/react": "^3.0.216",
    "ai": "^6.0.214",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.11",
    "lucide-react": "^0.468.0",
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shiki": "^1.24.0",
    "workers-ai-provider": "^3.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.0",
    "jsdom": "^25.0.1",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8",
    "wrangler": "^4.105.0"
  }
}
